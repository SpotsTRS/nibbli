# ── Nibbli Frontend Environment Variables ─────────────────────────────────
#
# For LOCAL development: copy this to .env — the defaults work out of the box.
# For VERCEL deployment: set VITE_BACKEND_URL in the Vercel dashboard under
#   Project Settings → Environment Variables. Do NOT commit a .env file.

# Your Render/Railway backend URL.
# Local default (no change needed for local dev):
VITE_BACKEND_URL=http://localhost:3001
# Production example:
# VITE_BACKEND_URL=https://nibbli-backend.onrender.com
