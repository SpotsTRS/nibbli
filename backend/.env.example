# ── Nibbli Backend Environment Variables ──────────────────────────────────
#
# Copy this file to .env for local development.
# On Render/Railway, set these in the dashboard instead of using a .env file.

# PORT is set automatically by Render/Railway. Only set this locally if 3001 conflicts.
PORT=3001

# Your Vercel frontend URL. Used to allow the browser to connect to this backend.
# Multiple URLs can be comma-separated.
# Example: FRONTEND_URL=https://nibbli.vercel.app
# Example with preview: FRONTEND_URL=https://nibbli.vercel.app,https://nibbli-git-main.vercel.app
FRONTEND_URL=http://localhost:5173
